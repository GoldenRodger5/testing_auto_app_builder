# Supabase
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Anthropic API key — set as a Supabase secret, NOT a frontend env var
# Only needed for local development via Vite proxy:
ANTHROPIC_API_KEY=sk-ant-your-key-here

# In production, the Anthropic API key is stored as a Supabase Edge Function secret:
# supabase secrets set ANTHROPIC_API_KEY=sk-ant-your-key-here
